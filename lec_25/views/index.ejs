<!DOCTYPE html>
<html>
<head>
    <title>Products</title>
</head>
<body>

<h1>All Products</h1>

<% Products.forEach((data) => { %>

    <img src="<%= data.url %>" height="200" width="200">

    <h2><%= data.Pname %></h2>
    <h4>Price: <%= data.Pprice %></h4>

    <a href="/product/<%= data.Pid %>"><button>Show</button></a>
    <a href="/product/<%= data.Pid %>/edit"><button>Edit</button></a>

    <!-- ✅ DELETE -->
    <form action="/product/<%= data.Pid %>?_method=DELETE" method="POST" style="display:inline;">
        <button type="submit">Delete</button>
    </form>

    <hr>

<% }) %>

<a href="/products/new">Add New Product</a>

</body>
</html>